#!/bin/bash
#
# macOS-specific implementation of `./script/run`. Runs a local version of
# Zap as a real 'app' instead of a bare executable, so macOS can treat it
# like a real signed app (custom URL schemes, user notifications, etc.).
#
# This script is invoked by `./script/run`, which handles cross-platform
# setup (install_channel_config, binary name detection, feature-to-env-var
# mapping). The following env vars are expected to be set by the caller:
#   ZAPLEX_BIN_NAME  — "warp" (internal local build) or "zap-oss"
#   ZAPLEX_CHANNEL   — "local" or "oss"
#   FEATURES       — comma-separated cargo features (already normalized)
# Must be called from the root directory of the warp repo.

set -e

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")"/../.. && pwd)"
cd "${REPO_ROOT}"

: "${ZAPLEX_BIN_NAME:?ZAPLEX_BIN_NAME must be set (invoke via ./script/run)}"
: "${ZAPLEX_CHANNEL:?ZAPLEX_CHANNEL must be set (invoke via ./script/run)}"
: "${FEATURES:?FEATURES must be set (invoke via ./script/run)}"

if [ "$ZAPLEX_CHANNEL" = "local" ]; then
    ZAPLEX_APP_PATH="target/debug/bundle/osx/WarpLocal.app"
    ZAPLEX_SCHEME_NAME="warplocal"
else
    ZAPLEX_APP_PATH="target/debug/bundle/osx/Zaplex.app"
    ZAPLEX_SCHEME_NAME="zaplex"
fi
DONT_OPEN=false
# Launches the binary with "open", meaning the Zap process is
# launched by the MacOS application launcher instead of a shell session.
# Note that since Zap isn't launched as a child process, using ctrl+c
# won't kill the app (but will kill the tail process displaying output).
# tl;dr better simulates running Zap Dev/Stable
OPEN_WITH_LAUNCHD=false

# Arguments to pass directly Zap (specified after --)
# This is not supported when opening with launchd, as passing CLI arguments to
# an application doesn't make sense.
ZAPLEX_ARGS=()

# Export this variable so it can be referenced by app/build.rs later when
# running `cargo bundle`.
export FRAMEWORK_OVERRIDE="dev"

PARAMS=""
while (( "$#" )); do
  case "$1" in
    --)
      shift
      ZAPLEX_ARGS=("$@")
      break
      ;;
    --dont-open)
      DONT_OPEN=true
      shift
      ;;
    --release)
      echo "Detected release build, pointing at release bundle under target/release/bundle"
      if [ "$ZAPLEX_CHANNEL" = "local" ]; then
          ZAPLEX_APP_PATH="target/release/bundle/osx/WarpLocal.app"
      else
          ZAPLEX_APP_PATH="target/release/bundle/osx/Zaplex.app"
      fi
      PARAMS="$PARAMS $1"
      shift
      ;;
    --profile)
      PROFILE="$2"
      shift 2
      if [ "$ZAPLEX_CHANNEL" = "local" ]; then
          ZAPLEX_APP_PATH="target/${PROFILE}/bundle/osx/WarpLocal.app"
      else
          ZAPLEX_APP_PATH="target/${PROFILE}/bundle/osx/Zaplex.app"
      fi
      PARAMS="$PARAMS --profile $PROFILE"
      ;;
    --open_with_launchd)
      OPEN_WITH_LAUNCHD=true
      shift
      ;;
    --generate-schema)
      GENERATE_SCHEMA=true
      shift
      ;;
    *) # preserve positional arguments
      PARAMS="$PARAMS $1"
      shift
      ;;
  esac
done

rm -rf "$ZAPLEX_APP_PATH"

pushd app > /dev/null
echo "Bundling app (bin: $ZAPLEX_BIN_NAME)..."
cargo bundle --bin "$ZAPLEX_BIN_NAME" --features "$FEATURES" $PARAMS
echo "Successfully bundled..."
popd > /dev/null

echo "Adding rpath to support mac frameworks"
install_name_tool -add_rpath "@executable_path/../Frameworks" "$ZAPLEX_APP_PATH/Contents/MacOS/$ZAPLEX_BIN_NAME"

export ZAPLEX_SCHEME_NAME
export ZAPLEX_PLIST_PATH="$ZAPLEX_APP_PATH/Contents/Info.plist"
./script/update_plist

echo "Preparing bundled resources..."
if [ "${GENERATE_SCHEMA:-false}" != "true" ]; then
  export SKIP_SETTINGS_SCHEMA=1
fi
# Pass FEATURES through (and an empty cargo profile, since this script does
# not configure one) so that the schema generation reuses the same compiled
# artifacts as the cargo bundle invocation above.
NO_LICENSES=1 "${REPO_ROOT}/script/prepare_bundled_resources" "$ZAPLEX_APP_PATH/Contents/Resources" "$ZAPLEX_CHANNEL" "" "$FEATURES"

"${REPO_ROOT}/script/compile_icon" "$ZAPLEX_CHANNEL" "$ZAPLEX_APP_PATH"

if [[ ",$FEATURES," =~ ",heap_usage_tracking," ]]; then
  echo "Bundling pprof..."
  HELPERS_DIR="$ZAPLEX_APP_PATH/Contents/Helpers"
  "${REPO_ROOT}/script/prepare_bundled_pprof" "$HELPERS_DIR"
fi

echo "Codesigning app..."
SIGNING_CERT="$(security find-identity -p codesigning -v | grep "Apple Development" | awk '{print $2}' | head -1)"
codesign --force --deep --options runtime --sign "${SIGNING_CERT:--}" "$ZAPLEX_APP_PATH" --entitlements script/Debug-Entitlements.plist

if [ "$DONT_OPEN" = false ] ; then
    if  [ "$OPEN_WITH_LAUNCHD" = true ]; then
        echo "Launching with MacOS application launcher"
        PATH="" /usr/bin/open "./$ZAPLEX_APP_PATH"
        tail -f ~/Library/Logs/warp_local.log
    else
        echo "Opening app at ./$ZAPLEX_APP_PATH/Contents/MacOS/$ZAPLEX_BIN_NAME"
        "./$ZAPLEX_APP_PATH/Contents/MacOS/$ZAPLEX_BIN_NAME" "${ZAPLEX_ARGS[@]}"
    fi
fi
